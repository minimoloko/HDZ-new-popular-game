  m_text: "MELLSTROY: \u0412\u041E\u0417\u0412\u0420\u0410\u0429\u0415\u041D\u0418\u0415
    \u0412 \u041A\u041E\u0422\u041B\u042B\n\u0418\u0433\u0440\u0430, \u0437\u0430\u0441\u043B\u0443\u0436\u0438\u0432\u0430\u044E\u0449\u0430\u044F
    600 \u0431\u0430\u043B\u043B\u043E\u0432\n\n\u041A\u041E\u041D\u0426\u0415\u041F\u0426\u0418\u042F\n\u041F\u0430\u0432\u0435\u043B
    \u0410\u043B\u0433\u043E\u0431\u0430\u043A\n\n\u0421\u0426\u0415\u041D\u0410\u0420\u0418\u0419
    \u0418 \u041B\u041E\u0420\n\u041E\u0441\u043D\u043E\u0432\u043D\u043E\u0439 \u0441\u044E\u0436\u0435\u0442,
    \u0434\u0438\u0430\u043B\u043E\u0433\u0438, \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0435
    \u043E\u0442\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u044F\n\u041F\u0430\u0432\u0435\u043B
    \u0410\u043B\u0433\u043E\u0431\u0430\u043A\n\n\u0421\u044E\u0436\u0435\u0442\u043D\u044B\u0435
    \u0440\u0430\u0437\u0432\u0438\u043B\u043A\u0438 \u0438 \u043A\u043E\u043D\u0446\u043E\u0432\u043A\u0438\n\u0418\u0432\u0430\u043D
    \u0410\u043B\u0433\u043E\u0431\u0430\u043A\n\n\u0425\u0440\u043E\u043D\u043E\u043B\u043E\u0433\u0438\u044F
    \u0441\u043E\u0431\u044B\u0442\u0438\u0439 \u0438 \u0442\u0430\u0439\u043C\u043B\u0430\u0439\u043D\n\u041C\u0438\u0445\u0430\u0438\u043B
    \u0410\u043B\u0433\u043E\u0431\u0430\u043A\n\n\u041F\u0420\u041E\u0412\u0415\u0420\u041A\u0410
    \u041D\u0410 \u041B\u041E\u0413\u0418\u0427\u041D\u041E\u0421\u0422\u042C\n\u041C\u0438\u0445\u0430\u0438\u043B
    \u0410\u043B\u0433\u043E\u0431\u0430\u043A\n\n\u0410\u041A\u0422\u0401\u0420\u0421\u041A\u0418\u0419
    \u0421\u041E\u0421\u0422\u0410\u0412\n\u041C\u0435\u043B\u043B\u0441\u0442\u0440\u043E\u0439
    (\u0433\u043E\u043B\u043E\u0441, \u043C\u0438\u043C\u0438\u043A\u0430, \u0445\u0430\u0440\u0438\u0437\u043C\u0430)
    \u2014 \u041F\u0430\u0432\u0435\u043B \u0410\u043B\u0433\u043E\u0431\u0430\u043A\n\u0413\u0435\u043D\u0435\u0440\u0430\u043B
    \u041A\u043E\u0442\u043B\u043E\u0432\u044B\u0439 \u2014 \u041F\u0430\u0432\u0435\u043B
    \u0410\u043B\u0433\u043E\u0431\u0430\u043A\n\u0420\u044F\u0434\u043E\u0432\u043E\u0439
    \u0414\u043E\u0442\u0435\u0440 \u2014 \u041F\u0430\u0432\u0435\u043B \u0410\u043B\u0433\u043E\u0431\u0430\u043A\n\u0411\u0430\u0440\u0438\u0441\u0442\u0430
    \u0438\u0437 \u0448\u0442\u0430\u0431\u0430 \u2014 \u0418\u0432\u0430\u043D \u0410\u043B\u0433\u043E\u0431\u0430\u043A\n\u0418\u0418-\u0430\u0441\u0441\u0438\u0441\u0442\u0435\u043D\u0442 
    \u2014 Qwen Studio\n\u0421\u0442\u0430\u0442\u0438\u0441\u0442\u044B, \u043C\u0430\u0441\u0441\u043E\u0432\u043A\u0430,
    \u043A\u0440\u0438\u043A\u0438 \u0432 \u0447\u0430\u0442\u0435 \u2014 \u041F\u0430\u0432\u0435\u043B
    \u0410\u043B\u0433\u043E\u0431\u0430\u043A\n\u0414\u0432\u043E\u0439\u043D\u0438\u043A\u0438,
    \u043A\u0430\u0441\u043A\u0430\u0434\u0451\u0440\u044B, \u043F\u043E\u0434\u0441\u0442\u0430\u0432\u043D\u044B\u0435
    \u043B\u0438\u0446\u0430 \u2014 \u0418\u0432\u0430\u043D \u0410\u043B\u0433\u043E\u0431\u0430\u043A\n\n\u0413\u0415\u0419\u041C\u0414\u0418\u0417\u0410\u0419\u041D
    \u0418 \u0411\u0410\u041B\u0410\u041D\u0421\n\u041C\u0435\u0445\u0430\u043D\u0438\u043A\u0438
    \u0434\u043E\u043D\u0430\u0442\u0430, \u0434\u0440\u043E\u043F\u0430 \u0438 \u044D\u0432\u0430\u043A\u0443\u0430\u0446\u0438\u0438\n\u0418\u0432\u0430\u043D
    \u0410\u043B\u0433\u043E\u0431\u0430\u043A\n\n\u042D\u043A\u043E\u043D\u043E\u043C\u0438\u043A\u0430
    \u0432\u043D\u0443\u0442\u0440\u0438\u0438\u0433\u0440\u043E\u0432\u043E\u0433\u043E
    \u043C\u0438\u0440\u0430\n\u041C\u0438\u0445\u0430\u0438\u043B \u0410\u043B\u0433\u043E\u0431\u0430\u043A\n\n\u041D\u0430\u0441\u0442\u0440\u043E\u0439\u043A\u0430
    \u0441\u043B\u043E\u0436\u043D\u043E\u0441\u0442\u0438 (\u043E\u043D\u0430 \u0435\u0441\u0442\u044C,
    \u043D\u043E \u0432\u044B \u0435\u0435 \u043D\u0435 \u0437\u0430\u043C\u0435\u0442\u0438\u043B\u0438)\n\u041C\u0438\u0445\u0430\u0438\u043B
    \u0410\u043B\u0433\u043E\u0431\u0430\u043A\n\n\u041F\u0440\u043E\u0442\u043E\u0442\u0438\u043F\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435
    \u0438 \u0431\u0430\u043B\u0430\u043D\u0441 \u043E\u0440\u0443\u0436\u0438\u044F\n\u041F\u0430\u0432\u0435\u043B
    \u0410\u043B\u0433\u043E\u0431\u0430\u043A\n\n\u041F\u0420\u041E\u0413\u0420\u0410\u041C\u041C\u0418\u0420\u041E\u0412\u0410\u041D\u0418\u0415\n\n\u041E\u043F\u0442\u0438\u043C\u0438\u0437\u0430\u0446\u0438\u044F
    \u0434\u043B\u044F \u0441\u043B\u0430\u0431\u044B\u0445 \u041F\u041A\n\u0418\u0432\u0430\u043D
    \u0410\u043B\u0433\u043E\u0431\u0430\u043A\n\n\u0428\u0435\u0439\u0434\u0435\u0440\u044B,
    \u043F\u043E\u0441\u0442-\u043E\u0431\u0440\u0430\u0431\u043E\u0442\u043A\u0430,
    HDR\n\u041F\u0430\u0432\u0435\u043B \u0410\u043B\u0433\u043E\u0431\u0430\u043A\n\n\u0418\u043D\u0442\u0435\u0433\u0440\u0430\u0446\u0438\u044F
    \u0441 \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043E\u043C\n\u041C\u0438\u0445\u0430\u0438\u043B
    \u0410\u043B\u0433\u043E\u0431\u0430\u043A\n\n\u0410\u0420\u0422 \u0418 \u0410\u041D\u0418\u041C\u0410\u0426\u0418\u042F\n\u041A\u043E\u043D\u0446\u0435\u043F\u0442-\u0430\u0440\u0442,
    \u0442\u0435\u043A\u0441\u0442\u0443\u0440\u044B, UI/UX\n\u0418\u0432\u0430\u043D
    \u0410\u043B\u0433\u043E\u0431\u0430\u043A, \u041F\u0430\u0432\u0435\u043B \u0410\u043B\u0433\u043E\u0431\u0430\u043A\n\n\u0420\u0438\u0433\u0433\u0438\u043D\u0433,
    \u0441\u043A\u0435\u043B\u0435\u0442\u043D\u0430\u044F \u0430\u043D\u0438\u043C\u0430\u0446\u0438\u044F,
    \u044D\u043C\u043E\u0446\u0438\u0438\n\u041C\u0438\u0445\u0430\u0438\u043B \u0410\u043B\u0433\u043E\u0431\u0430\u043A\n\n\u0412\u0438\u0437\u0443\u0430\u043B\u044C\u043D\u044B\u0435
    \u044D\u0444\u0444\u0435\u043A\u0442\u044B, \u0432\u0437\u0440\u044B\u0432\u044B,
    \u0434\u044B\u043C \u043A\u043E\u0442\u043B\u043E\u0432\n\u041C\u0438\u0445\u0430\u0438\u043B
    \u0410\u043B\u0433\u043E\u0431\u0430\u043A\n\n\u041C\u043E\u0434\u0435\u043B\u0438
    \u043E\u043A\u0440\u0443\u0436\u0435\u043D\u0438\u044F \u0438 \u043F\u0440\u043E\u043F\u0441\u044B\n\u0418\u0432\u0430\u043D
    \u0410\u043B\u0433\u043E\u0431\u0430\u043A\n\n\u0418\u043B\u043B\u044E\u0441\u0442\u0440\u0430\u0446\u0438\u0438
    \u0434\u043B\u044F \u0437\u0430\u0433\u0440\u0443\u0437\u043E\u0447\u043D\u044B\u0445
    \u044D\u043A\u0440\u0430\u043D\u043E\u0432\n\u0418\u0432\u0430\u043D \u0410\u043B\u0433\u043E\u0431\u0430\u043A\n\n\u0417\u0412\u0423\u041A
    \u0418 \u041C\u0423\u0417\u042B\u041A\u0410\n\u0421\u0430\u0443\u043D\u0434\u0442\u0440\u0435\u043A,
    \u044D\u043C\u0431\u0438\u0435\u043D\u0442, \u0433\u0443\u043B \u0433\u0435\u043D\u0435\u0440\u0430\u0442\u043E\u0440\u043E\u0432\n\u0418\u0432\u0430\u043D
    \u0410\u043B\u0433\u043E\u0431\u0430\u043A\n\n\u041E\u0437\u0432\u0443\u0447\u043A\u0430,
    \u0448\u0443\u043C\u044B, \u0440\u0435\u043F\u043B\u0438\u043A\u0438 \u0432 \u044D\u0444\u0438\u0440\u0435\n\u0418\u0432\u0430\u043D
    \u0410\u043B\u0433\u043E\u0431\u0430\u043A\n\n\u0421\u0432\u0435\u0434\u0435\u043D\u0438\u0435,
    \u043C\u0430\u0441\u0442\u0435\u0440\u0438\u043D\u0433, \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
    \u0437\u0432\u0443\u043A\n\u0418\u0432\u0430\u043D \u0410\u043B\u0433\u043E\u0431\u0430\u043A\n\n\n\u0422\u0415\u0421\u0422\u0418\u0420\u041E\u0412\u0410\u041D\u0418\u0415
    (QA)\n\u041F\u043E\u0438\u0441\u043A \u0431\u0430\u0433\u043E\u0432, \u0432\u044B\u043B\u0435\u0442\u043E\u0432
    \u0438 \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u043E\u0448\u0438\u0431\u043E\u043A\n\u0418\u0432\u0430\u043D
    \u0410\u043B\u0433\u043E\u0431\u0430\u043A\n\u041F\u0430\u0432\u0435\u043B \u0410\u043B\u0433\u043E\u0431\u0430\u043A\n\u041C\u0438\u0445\u0430\u0438\u043B
    \u0410\u043B\u0433\u043E\u0431\u0430\u043A (\u043D\u0430\u0434\u0435\u044E\u0441\u044C
    \u0432\u0441\u0435 \u0442\u0435\u0441\u0442\u0438\u043B\u0438)\n\n\u041B\u043E\u043A\u0430\u043B\u0438\u0437\u0430\u0446\u0438\u044F\n\u041F\u0435\u0440\u0435\u0432\u043E\u0434
    \u043D\u0430 \u0430\u043D\u0433\u043B\u0438\u0439\u0441\u043A\u0438\u0439, \u043A\u0438\u0442\u0430\u0439\u0441\u043A\u0438\u0439
    \u0438 \u044D\u043B\u044C\u0444\u0438\u0439\u0441\u043A\u0438\u0439\n\u0418\u0432\u0430\u043D
    \u0410\u043B\u0433\u043E\u0431\u0430\u043A\n\u041F\u0430\u0432\u0435\u043B \u0410\u043B\u0433\u043E\u0431\u0430\u043A\n\u041C\u0438\u0445\u0430\u0438\u043B
    \u0410\u043B\u0433\u043E\u0431\u0430\u043A\n\n\u0422\u0415\u0425\u041D\u0418\u0427\u0415\u0421\u041A\u0410\u042F
    \u041F\u041E\u0414\u0414\u0415\u0420\u0416\u041A\u0410\n\u0414\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u0430\u0446\u0438\u044F,
    \u0433\u0430\u0439\u0434\u044B, \u0432\u0438\u043A\u0438\n\u041F\u0430\u0432\u0435\u043B
    \u0410\u043B\u0433\u043E\u0431\u0430\u043A\n\n\u041C\u043E\u0434\u0434\u0438\u043D\u0433-\u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u044B
    \u0438 API \u0434\u043B\u044F \u0441\u043E\u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430\n\u041C\u0438\u0445\u0430\u0438\u043B
    \u0410\u043B\u0433\u043E\u0431\u0430\u043A\n\n\u0421\u0431\u043E\u0440\u043A\u0430
    \u0431\u0438\u043B\u0434\u043E\u0432 \u0438 CI/CD\n\u0418\u0432\u0430\u043D \u0410\u043B\u0433\u043E\u0431\u0430\u043A\n\n\u041F\u0420\u041E\u0414\u042E\u0421\u0418\u0420\u041E\u0412\u0410\u041D\u0418\u0415
    \u0418 \u0418\u0417\u0414\u0410\u041D\u0418\u0415\n\u041C\u0435\u043D\u0435\u0434\u0436\u043C\u0435\u043D\u0442,
    \u043C\u0430\u0440\u043A\u0435\u0442\u0438\u043D\u0433, \u0440\u0430\u0431\u043E\u0442\u0430
    \u0441 \u0441\u043E\u043E\u0431\u0449\u0435\u0441\u0442\u0432\u043E\u043C\n\u041F\u0430\u0432\u0435\u043B
    \u0410\u043B\u0433\u043E\u0431\u0430\u043A\n\n\u0424\u0438\u043D\u0430\u043D\u0441\u044B,
    \u0431\u0443\u0445\u0433\u0430\u043B\u0442\u0435\u0440\u0438\u044F, \u0437\u0430\u043A\u0443\u043F\u043A\u0430
    \u044D\u043D\u0435\u0440\u0433\u0435\u0442\u0438\u043A\u043E\u0432\n\u041C\u0438\u0445\u0430\u0438\u043B
    \u0410\u043B\u0433\u043E\u0431\u0430\u043A\n\n\u0421\u0442\u0440\u0430\u0442\u0435\u0433\u0438\u044F
    \u0440\u0435\u043B\u0438\u0437\u0430 \u0438 \u043F\u043E\u0441\u0442-\u043F\u043E\u0434\u0434\u0435\u0440\u0436\u043A\u0430\n\u0418\u0432\u0430\u043D
    \u0410\u043B\u0433\u043E\u0431\u0430\u043A\n\n\u041E\u0421\u041E\u0411\u0410\u042F
    \u0411\u041B\u0410\u0413\u041E\u0414\u0410\u0420\u041D\u041E\u0421\u0422\u042C\n\u041C\u0435\u043B\u043B\u0441\u0442\u0440\u043E\u0439,
    \u041C\u0438\u0445\u0430\u043B\u043A\u043E\u0432, \u041F\u0430\u0432\u0435\u043B
    \u0410\u043B\u0433\u043E\u0431\u0430\u043A, \u041A\u043E\u043D\u0441\u0442\u0430\u043D\u0442\u0438\u043D
    \u0420\u044B\u0447\u043A\u043E\u0432\n\n\u041F\u0420\u0415\u0414\u0421\u0422\u0410\u0412\u041B\u0415\u041D\u041E
    \u041A\u041E\u041C\u041F\u0410\u041D\u0418\u0415\u0419 \xAB\u0410\u041B\u0413\u041E\u0411\u0410\u041A
    \u0421\u0422\u0423\u0414\u0418\u041E\xBB\n\xA9 2026 \u0412\u0441\u0435 \u043F\u0440\u0430\u0432\u0430
    \u0437\u0430\u0449\u0438\u0449\u0435\u043D\u044B. \u041A\u043E\u0442\u043B\u044B
    \u2014 \u043D\u0435\u0442.\n\u0421\u043F\u0430\u0441\u0438\u0431\u043E \u0437\u0430
    \u0438\u0433\u0440\u0443. \u041F\u0435\u0440\u0435\u0437\u0430\u0433\u0440\u0443\u0437\u043A\u0430
    \u0441\u0438\u0441\u0442\u0435\u043C\u044B\u2026"
